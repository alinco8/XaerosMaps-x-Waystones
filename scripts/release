#!/usr/bin/env bash
# Requires: git, git-cliff, gum, gh, gradle, tomato
set -euo pipefail

fatal() {
  gum log -l fatal "$1"
  exit 1
}
info() {
  gum log -l info "$1"
}

if_prod() {
  if [[ "${DRY_RUN:-}" == "false" ]]; then
    "$@"
  fi
}

if [[ "${DRY_RUN:-}" != "false" ]]; then
  gum confirm "Dry run mode enabled. Proceed?" || fatal "Release aborted by user."
fi

if [[ -n "$(git status --porcelain)" ]]; then
  git status --porcelain | sed 's/^/  /' >&2 || true
  fatal "Working directory is dirty."
fi

git fetch --tags >/dev/null 2>&1

CURRENT_VERSION="$(tomato get mod.version stonecutter.properties.toml)"
NEXT_VERSION="$(git-cliff --unreleased --bumped-version | tr -d '[:space:]')"
NEXT_VERSION="${NEXT_VERSION#v}"

[[ -n "$NEXT_VERSION" ]] || fatal "git-cliff did not produce a bumped version."
[[ "$CURRENT_VERSION" != "$NEXT_VERSION" ]] || fatal "No new version detected. Already at $CURRENT_VERSION."

[[ -n "${MODRINTH_TOKEN:-}" ]] || fatal "MODRINTH_TOKEN is not set."
[[ -n "${CURSEFORGE_TOKEN:-}" ]] || fatal "CURSEFORGE_TOKEN is not set."

RELEASE_NOTES="$(git-cliff --unreleased --strip all)"
[[ -n "$RELEASE_NOTES" ]] || fatal "Release notes are empty."

info "Releasing... $CURRENT_VERSION -> $NEXT_VERSION"
info "Release notes:"
echo "$RELEASE_NOTES"

cleanup() {
  if [[ -n "$(git status --porcelain)" ]]; then
    git restore --source=HEAD --staged --worktree stonecutter.properties.toml >/dev/null 2>&1 || true
  fi
}
trap cleanup ERR INT

tomato set mod.version "$NEXT_VERSION" stonecutter.properties.toml

info "Building & publishing..."
rm -f build/libs/* || true
CHANGELOG=$RELEASE_NOTES ./gradlew buildAndCollect publishMods --warning-mode all

git add stonecutter.properties.toml
git commit -m "chore(release): v$NEXT_VERSION"
git tag "v$NEXT_VERSION"

tmp_notes="$(mktemp)"
printf '%s\n' "$RELEASE_NOTES" > "$tmp_notes"

BRANCH="$(git branch --show-current)"
if gum confirm "Push v$NEXT_VERSION to origin?"; then
  if_prod git push origin "$BRANCH" "v$NEXT_VERSION"
  if_prod gh release create "v$NEXT_VERSION" -F "$tmp_notes" build/libs/*
  info "Done!"
else
  info "Skipped push. Tag v$NEXT_VERSION is local only."
fi

rm -f "$tmp_notes"
